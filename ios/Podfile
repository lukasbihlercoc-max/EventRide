platform :ios, '14.0'

ENV['COCOAPODS_DISABLE_STATS'] = 'true'

project 'Runner', {
  'Debug' => :debug,
  'Profile' => :release,
  'Release' => :release,
}

def flutter_root
  generated_xcode_build_settings_path = File.expand_path(File.join('..', 'Flutter', 'Generated.xcconfig'), __FILE__)
  unless File.exist?(generated_xcode_build_settings_path)
    raise "#{generated_xcode_build_settings_path} must exist. If you're running pod install manually, make sure flutter pub get is called first"
  end

  File.foreach(generated_xcode_build_settings_path) do |line|
    matches = line.match(/FLUTTER_ROOT\=(.*)/)
    return matches[1].strip if matches
  end
  raise "FLUTTER_ROOT not found in #{generated_xcode_build_settings_path}. Try deleting Generated.xcconfig, then run flutter pub get"
end

require File.expand_path(File.join('packages', 'flutter_tools', 'bin', 'podhelper'), flutter_root)

flutter_ios_podfile_setup

target 'Runner' do
  use_frameworks! :linkage => :static
  use_modular_headers!

  flutter_install_all_ios_pods File.dirname(File.realpath(__FILE__))
  target 'RunnerTests' do
    inherit! :search_paths
  end
end

post_install do |installer|
  installer.pods_project.targets.each do |target|
    flutter_additional_ios_build_settings(target)
    target.build_configurations.each do |config|
      config.build_settings['IPHONEOS_DEPLOYMENT_TARGET'] = '14.0'

      # Xcode 26 / Clang 19 compatibility fixes for Firebase/gRPC pods:
      # 1. GCC_WARN_INHIBIT_ALL_WARNINGS=YES causes Xcode 26 to emit -GCC_WARN_INHIBIT_ALL_WARNINGS
      #    which Clang rejects for arm64-apple-ios (BoringSSL-GRPC)
      config.build_settings['GCC_WARN_INHIBIT_ALL_WARNINGS'] = 'NO'
      # 2. Prevent any pod warnings from being promoted to errors
      config.build_settings['GCC_TREAT_WARNINGS_AS_ERRORS'] = 'NO'
      config.build_settings['SWIFT_TREAT_WARNINGS_AS_ERRORS'] = 'NO'
      # 3. Suppress Clang 19 warning: template keyword without arg list (gRPC-Core)
      existing = config.build_settings['OTHER_CPLUSPLUSFLAGS'] || '$(inherited)'
      unless existing.include?('-Wno-missing-template-arg-list-after-template-kw')
        config.build_settings['OTHER_CPLUSPLUSFLAGS'] = "#{existing} -Wno-missing-template-arg-list-after-template-kw"
      end
    end
  end

  Dir.glob("#{installer.sandbox.root}/**/*.xcconfig").each do |file|
    content = File.read(file)
    new_content = content
      .gsub('GCC_WARN_INHIBIT_ALL_WARNINGS = YES', 'GCC_WARN_INHIBIT_ALL_WARNINGS = NO')
      .gsub('GCC_TREAT_WARNINGS_AS_ERRORS = YES', 'GCC_TREAT_WARNINGS_AS_ERRORS = NO')
      .gsub(/ -G[^ \n]*/, '')
    File.write(file, new_content) if new_content != content
  end
end
