# World4You FTP-Zugangsdaten (für deploy_website.ps1)
# FTP-Host: im World4You Kundencenter unter "FTP-Zugangsdaten"
FTP_HOST=fXXXX.world4you.com
FTP_USER=dein-benutzername
FTP_PASS=dein-passwort
# Ziel-Verzeichnis auf dem Server (meist public_html oder html)
FTP_PATH=/public_html/

# Codemagic API-Zugangsdaten
# Kopiere diese Datei als .env und trage deine Werte ein.
# .env wird NICHT in Git committed (steht in .gitignore).

# API-Token: Codemagic -> Nutzer-Icon (oben rechts) -> Integrations -> API tokens
CODEMAGIC_API_TOKEN=your_token_here

# App-ID: aus der URL wenn du die App in Codemagic oeffnest
# z.B. https://codemagic.io/app/6123abc.../builds -> 6123abc...
CODEMAGIC_APP_ID=your_app_id_here

# Workflow-ID: muss dem Schluessel in codemagic.yaml entsprechen
CODEMAGIC_WORKFLOW_ID=ios-release
