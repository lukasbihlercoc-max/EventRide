rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Eingeloggt?
    function isSignedIn() {
      return request.auth != null;
    }

    // Greift Nutzer auf sein eigenes Dokument zu?
    function isOwner(uid) {
      return request.auth.uid == uid;
    }

    // Hat der eingeloggte Nutzer Admin-Rechte?
    // Voraussetzung: Im Firestore-Dokument users/{uid} muss isAdmin: true gesetzt sein.
    function isAdmin() {
      return isSignedIn()
        && get(/databases/$(database)/documents/users/$(request.auth.uid)).data.get('isAdmin', false) == true;
    }

    // Darf der Nutzer den Event Manager (Web-Tool) verwenden?
    function isManager() {
      return isSignedIn()
        && request.auth.token.email in [
             'lukas.bihler.coc@gmail.com',
             'matzematze666@gmail.com',
             'chiara.bihler.cb@gmail.com'
           ];
    }

    // ----------------------------------------------------------------
    // users/{uid}
    //
    // Lesen:    Alle eingeloggten Nutzer (Fahrer-/Mitfahrernamen anzeigen)
    // Erstellen: Nur der eigene Account (uid muss mit auth.uid übereinstimmen)
    // Updaten:   Nur der eigene Account; email darf nicht geändert werden
    // Löschen:   Nur der eigene Account
    // ----------------------------------------------------------------
    match /users/{uid} {
      allow read:   if isSignedIn();
      allow create: if isOwner(uid)
                    && request.resource.data.keys().hasAll(['firstName', 'lastName', 'email']);
      allow update: if (isOwner(uid)
                        && request.resource.data.email == resource.data.email
                        && request.resource.data.get('isAdmin', false) == resource.data.get('isAdmin', false))
                    || (isAdmin()
                        && request.resource.data.get('email', '') == resource.data.get('email', '')
                        && request.resource.data.get('isAdmin', false) == resource.data.get('isAdmin', false));
      allow delete: if isOwner(uid);

      // ----------------------------------------------------------------
      // users/{uid}/private/{doc}
      //
      // Sensible Felder: phone, licenseRejectReason, licensePlate
      // Lesen/Schreiben: Nur Eigentümer oder Admin
      // (Admin braucht Schreibzugriff z.B. für rejectLicense() im Client)
      // ----------------------------------------------------------------
      match /private/{doc} {
        allow read:  if isOwner(uid) || isAdmin();
        allow write: if isOwner(uid) || isAdmin();
      }
    }

    // ----------------------------------------------------------------
    // fahrten/{fahrtId}
    //
    // Lesen:    Alle eingeloggten Nutzer (Fahrtensuche)
    // Erstellen: Eingeloggt + ownerId muss eigene UID sein
    //            + Pflichtfelder müssen vorhanden sein
    // Updaten:   Nur der Owner; ownerId darf nicht geändert werden
    // Löschen:   Nur der Owner
    // ----------------------------------------------------------------
    match /fahrten/{fahrtId} {
      allow read:   if isSignedIn();
      allow create: if isSignedIn()
                    && request.resource.data.ownerId == request.auth.uid
                    && request.resource.data.keys().hasAll([
                         'id', 'ownerId', 'eventId', 'eventName',
                         'abfahrtsort', 'standort', 'freiePlaetze'
                       ]);
      allow update: if isSignedIn()
                    && resource.data.ownerId == request.auth.uid
                    && request.resource.data.ownerId == resource.data.ownerId;
      allow delete: if isSignedIn()
                    && resource.data.ownerId == request.auth.uid;
    }


    // ----------------------------------------------------------------
    // anfragen/{anfrageId}
    //
    // Lesen:    Nur Requester und Fahrer der jeweiligen Anfrage
    // Erstellen: Eingeloggt + requesterId muss eigene UID sein
    //            + Pflichtfelder müssen vorhanden sein
    // Updaten:   Fahrer (fahrtOwnerId) oder Requester (requesterId)
    // Löschen:   Nicht erlaubt (Status wird auf 'abgelehnt' gesetzt)
    // ----------------------------------------------------------------
    match /anfragen/{anfrageId} {
      allow read:   if isSignedIn()
                    && (request.auth.uid == resource.data.requesterId
                        || request.auth.uid == resource.data.fahrtOwnerId);
      // Mitfahrer erstellt eigene Anfrage ODER Fahrer lädt Interessenten ein
      // Selbst-Anfragen (requesterId == fahrtOwnerId) sind nicht erlaubt
      allow create: if isSignedIn()
                    && (request.resource.data.requesterId == request.auth.uid
                        || request.resource.data.fahrtOwnerId == request.auth.uid)
                    && request.resource.data.requesterId != request.resource.data.fahrtOwnerId
                    && request.resource.data.keys().hasAll([
                         'id', 'fahrtId', 'requesterId', 'fahrtOwnerId', 'status'
                       ]);
      // Mitfahrer darf nur ablehnen (2) oder stornieren (3) — NICHT akzeptieren (1)
      // Fahrer darf alles (inkl. Akzeptieren von Anfragen der Mitfahrer)
      // status=1 für requesterId ist ausschließlich der Cloud Function vorbehalten
      allow update: if isSignedIn()
                    && (
                      (resource.data.requesterId == request.auth.uid
                        && request.resource.data.status in [2, 3])
                      || resource.data.fahrtOwnerId == request.auth.uid
                    );
      allow delete: if false;
    }

    // ----------------------------------------------------------------
    // interessenten/{docId}   (Dokument-ID: {eventId}_{userId})
    //
    // Lesen:    Alle eingeloggten Nutzer (Fahrer sehen die Liste)
    // Erstellen: Nur der eigene User (userId muss eigene UID sein)
    // Löschen:   Nur der eigene User
    // Updaten:   Nicht nötig (toggle = delete + create)
    // ----------------------------------------------------------------
    match /interessenten/{docId} {
      allow read:   if isSignedIn();
      allow create: if isSignedIn()
                    && request.resource.data.userId == request.auth.uid
                    && request.resource.data.keys().hasAll([
                         'eventId', 'userId', 'userName'
                       ]);
      allow delete: if isSignedIn()
                    && resource.data.userId == request.auth.uid;
      allow update: if isSignedIn()
                    && resource.data.userId == request.auth.uid;
    }

    // ----------------------------------------------------------------
    // chat_conversations/{conversationId}
    //
    // Lesen:    Nur Teilnehmer – resource == null erlaubt den
    //           Existenz-Check in ensureConversation (Transaction get())
    // Erstellen: Nur wenn eigene UID in participants
    // Updaten:  Nur Teilnehmer (lastMessage / lastMessageAt)
    // Löschen:  Nicht erlaubt
    // ----------------------------------------------------------------
    // ----------------------------------------------------------------
    // events/{eventId}
    //
    // Lesen:    Alle eingeloggten Nutzer
    // Schreiben: Nur Admin
    // ----------------------------------------------------------------
    match /events/{eventId} {
      allow read:  if true;
      allow write: if isAdmin() || isManager();
    }

    // ----------------------------------------------------------------
    // password_reset_attempts/{email}
    //
    // Rate-Limit-Tracking für sendPasswordResetEmailCustom — nur die Cloud
    // Function (Admin SDK) darf lesen/schreiben, kein Client-Zugriff.
    // ----------------------------------------------------------------
    match /password_reset_attempts/{email} {
      allow read, write: if false;
    }

    // ----------------------------------------------------------------
    // licenseRequests/{uid}
    //
    // Erstellen: Nur der eigene Nutzer (status muss 'pending' sein)
    // Updaten:   Eigener Nutzer (nur als 'pending', uid unveränderlich)
    //            ODER Admin (für approve/reject)
    // Lesen:     Nur Eigentümer + Admin
    // Löschen:   Nie
    // ----------------------------------------------------------------
    match /licenseRequests/{uid} {
      allow create: if isSignedIn() && isOwner(uid)
                    && request.resource.data.status == 'pending';
      allow update: if (isSignedIn() && isOwner(uid)
                        && request.resource.data.status == 'pending'
                        && request.resource.data.uid == request.auth.uid)
                    || isAdmin();
      allow read:   if isSignedIn() && (isOwner(uid) || isAdmin());
      allow delete: if isSignedIn() && isOwner(uid);
    }

    // ----------------------------------------------------------------
    // eventRequests/{requestId}
    //
    // Erstellen: Eingeloggt, eigene UID, status='pending'
    // Lesen:     Eigener Nutzer oder Admin
    // Updaten:   Nur Admin (approve / discard)
    // Löschen:   Nie
    // ----------------------------------------------------------------
    match /eventRequests/{requestId} {
      allow create: if isSignedIn()
                    && request.resource.data.uid == request.auth.uid
                    && request.resource.data.status == 'pending';
      allow read:   if isSignedIn()
                    && (request.auth.uid == resource.data.uid || isAdmin());
      allow update: if isAdmin();
      allow delete: if isSignedIn() && request.auth.uid == resource.data.uid;
    }

    // ----------------------------------------------------------------
    // reviews/{reviewId}   (ID: {fahrtId}_{reviewedId})
    //
    // Lesen:    Alle eingeloggten Nutzer (Anzeige auf Profilseiten)
    // Update/Delete: verboten für Nutzer — nur Admin darf löschen
    // ----------------------------------------------------------------
    match /reviews/{reviewId} {
      allow read:   if isSignedIn();
      allow create: if false;
      allow update: if false;
      allow delete: if isAdmin();
    }

    // ----------------------------------------------------------------
    // review_reports/{docId}
    //
    // Erstellen: Eingeloggt + reporterId muss eigene UID sein
    // Lesen/Updaten/Löschen: Nur Admin (Server-SDK)
    // ----------------------------------------------------------------
    match /review_reports/{docId} {
      allow create: if isSignedIn()
                    && request.resource.data.reporterId == request.auth.uid;
      allow read, update, delete: if false;
    }

    // ----------------------------------------------------------------
    // user_reports/{docId}
    //
    // Erstellen: Eingeloggt + reporterUid muss eigene UID sein
    // Lesen/Updaten/Löschen: Nicht erlaubt (Server-SDK)
    // ----------------------------------------------------------------
    match /user_reports/{docId} {
      allow create: if isSignedIn()
                    && request.resource.data.reporterUid == request.auth.uid;
      allow read: if isAdmin();
      allow update, delete: if false;
    }

    // ----------------------------------------------------------------
    // pending_events/{docId}  (Manager-internes Admin-Tool)
    //
    // Lesen/Schreiben: Nur eingeloggte Nutzer (nur über Admin-HTML erreichbar)
    // ----------------------------------------------------------------
    match /pending_events/{docId} {
      allow read, write: if isManager();
    }

    // ----------------------------------------------------------------
    // ig_accounts/{docId}  (Instagram-Recherche-Tracking)
    //
    // Lesen/Schreiben: Nur Manager (internes Tool)
    // ----------------------------------------------------------------
    match /ig_accounts/{docId} {
      allow read, write: if request.auth != null && request.auth.token.email == "lukas.bihler.coc@gmail.com";
    }

    // ----------------------------------------------------------------
    // gemeinde_meta/{docId}  (Recherche-Status pro Gemeinde)
    //
    // Lesen/Schreiben: Nur lukas.bihler.coc@gmail.com
    // ----------------------------------------------------------------
    match /gemeinde_meta/{docId} {
      allow read, write: if request.auth != null && request.auth.token.email == "lukas.bihler.coc@gmail.com";
    }

    match /chat_conversations/{conversationId} {
      allow read: if isSignedIn()
                  && (resource == null
                      || request.auth.uid in resource.data.participants);
      allow create: if isSignedIn()
                    && request.auth.uid in request.resource.data.participants;
      allow update: if isSignedIn()
                    && request.auth.uid in resource.data.participants;
      allow delete: if false;

      // ----------------------------------------------------------------
      // messages/{messageId}
      //
      // Lesen:    Nur Teilnehmer der übergeordneten Conversation.
      // Erstellen/Updaten: Nur Teilnehmer + E-Mail muss verifiziert sein.
      // Löschen: Nur Teilnehmer (kein E-Mail-Check, z.B. bei Account-Löschung).
      // get() liest das Parent-Dokument für den Participants-Check.
      // ----------------------------------------------------------------
      match /messages/{messageId} {
        allow read: if isSignedIn()
                    && request.auth.uid in get(
                         /databases/$(database)/documents/chat_conversations/$(conversationId)
                       ).data.participants;
        allow create, update: if isSignedIn()
                     && request.auth.token.email_verified == true
                     && request.auth.uid in get(
                          /databases/$(database)/documents/chat_conversations/$(conversationId)
                        ).data.participants;
        allow delete: if false;
      }
    }

  }
}
